@model IEnumerable<ECommerceMvc.Models.Order>
@{
    ViewData["Title"] = "Manage Orders";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Manage Orders</h2>
</div>

<div class="surface-panel">
    <div class="table-responsive">
        <table class="table table-striped align-middle admin-table mb-0">
            <thead>
                <tr>
                    <th>Order ID</th>
                    <th>Customer Name</th>
                    <th>Total Price</th>
                    <th>Order Date</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var order in Model)
                {
                    <tr>
                        <td>#@order.Id</td>
                        <td>@order.FullName</td>
                        <td>@order.TotalPrice.ToString("C")</td>
                        <td>@order.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            <span class="badge order-status-badge status-@order.Status.ToLowerInvariant()">@order.Status</span>
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@order.Id" class="btn btn-sm btn-outline-primary">View Details</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
