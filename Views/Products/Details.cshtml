@model ECommerceMvc.Models.Product
@{
    ViewData["Title"] = "Product Details";
}

<section class="page-head mb-3">
    <h2 class="mb-1">Product Details</h2>
    <p class="mb-0">View product information and stock availability before adding to cart.</p>
</section>

<div class="row g-4 details-layout">
    <div class="col-lg-6">
        <div class="surface-panel h-100 detail-media-panel">
            <img src="@Model.ImageUrl" class="img-fluid rounded detail-image" alt="@Model.Name" />
        </div>
    </div>
    <div class="col-lg-6">
        <div class="surface-panel h-100">
            <h2>@Model.Name</h2>
            <p class="text-muted">@Model.Description</p>
            <p class="h4 text-success">@Model.Price.ToString("C")</p>
            <p class="product-quantity mb-3">Available: <span>@Model.Quantity</span></p>

            <form asp-controller="Cart" asp-action="Add" method="post" class="mt-3 d-flex flex-wrap gap-2">
                <input type="hidden" name="productId" value="@Model.Id" />
                <button class="btn btn-primary" disabled="@(Model.Quantity <= 0)">Add to Cart</button>
                <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Back</a>
            </form>
        </div>
    </div>
</div>
